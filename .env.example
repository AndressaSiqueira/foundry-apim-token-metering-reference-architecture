# ============================================================
# foundry-apim-token-metering-reference-architecture
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ----- Azure subscription / resource group ------------------
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=rg-token-metering
AZURE_LOCATION=eastus2

# ----- APIM gateway -----------------------------------------
# Populated after infrastructure deployment
APIIM_GATEWAY_URL=https://<your-apim-name>.azure-api.net
APIIM_SUBSCRIPTION_KEY=<apim-subscription-key-for-this-tenant>

# ----- Tenant / consumer identity ---------------------------
# These values are sent as custom dimensions to APIM and OTel
APP_TENANT_ID=tenant-a
APP_CONSUMER_NAME=sample-agent

# ----- Azure AI Foundry (LOCAL DEV ONLY) --------------------
# In production, APIM authenticates to Foundry via Managed Identity.
# Only set these for direct local testing without APIM.
# FOUNDRY_ENDPOINT=https://<your-ai-project>.cognitiveservices.azure.com/
# FOUNDRY_API_KEY=<only-for-local-dev-never-commit>

# ----- OpenTelemetry ----------------------------------------
OTEL_SERVICE_NAME=foundry-agent-app
OTEL_SERVICE_VERSION=1.0.0
# OTLP HTTP exporter endpoint (Azure Monitor OTLP endpoint or local collector)
OTEL_EXPORTER_OTLP_ENDPOINT=https://<region>.otelcollector.monitor.azure.com/

# Application Insights connection string (Azure Monitor exporter)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<guid>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# ----- Privacy controls -------------------------------------
# Hash prompt/response content with SHA-256 before logging (recommended for production)
LOG_CONTENT_HASH_ENABLED=true
# Completely suppress prompt/response content from all logs
LOG_CONTENT_REDACT_ENABLED=false

# ----- App feature flags ------------------------------------
ENABLE_STREAMING=false
DEFAULT_MODEL_DEPLOYMENT=gpt-4o
MAX_TOKENS=2048
TEMPERATURE=0.7
